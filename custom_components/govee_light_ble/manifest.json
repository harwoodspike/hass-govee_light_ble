{
    "domain": "govee_light_ble",
    "name": "GOVEE Bluetooth Lights",
    "bluetooth": [
        { "local_name": "Govee_*", "connectable": false },
        { "local_name": "ihoment_*", "connectable": false },
        { "local_name": "GBK_*", "connectable": false }
    ],
    "codeowners": ["@harwoodspike"],
    "config_flow": true,
    "dependencies": ["bluetooth"],
    "documentation": "https://github.com/harwoodspike/hass-govee_light_ble",
    "iot_class": "local_polling",
    "issue_tracker": "https://github.com/harwoodspike/hass-govee_light_ble/issues",
    "requirements": ["bleak-retry-connector"],
    "version": "2.7.5"
}
